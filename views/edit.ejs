<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <div class="post-btn hide">
            <div class="post-content">

                <div class="post-header">
                    <h2>New Post</h2>
                </div>
                <div class="post-input">
                    <p>title</p>
                    <input type="text" class="input-text" value="<%=title%>">
                </div>
                <div class="post-input">
                    <p>topic</p>
                    <select name="" id="" class="select-data">
                        <option value="Technology">Technology</option>
                        <option value="Finance">Finance</option>
                        <option value="Business">Business</option>
                        <option value="AI">AI</option>
                        <option value="Economy">Economy</option>
                        <option value="Health">Health</option>
                        <option value="Entertainment">Entertainment</option>
                        <option value="Other">Other</option>
                    </select>
                </div>
                <div class="post-input">
                    <p>content</p>
                    <textarea class="content-data"><%=content%></textarea>
                </div>

                <div class="submit-btn">
                    <input type="button" value="Cancel" class="post-cancel">
                    <input type="hidden" id="post-id" value="<%=id%>">
                    <input type="button" value="Submit" class="edit-submit">
                </div>
            </div>
        </div>
        <script src="/index.js"></script>
</body>
</html>