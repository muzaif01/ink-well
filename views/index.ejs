<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <link rel="stylesheet" href="/style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">

</head>

<body>

    <div class="website">



        <div class="navbar">
            <%-include("partials/navbar.ejs")%>
        </div>

        <div class="for-grid">
               
            <div class="main-content">
        
            </div>

            <div class="search-left">
                <div class="search-bar">
                    <div class="search">
                        <input type="text" name="search" id="search-text" placeholder="Search..">
                    </div>
                    <div class="search-items">
                        <button class="search-btn" value="Technology">Technology</button>
                        <button class="search-btn" value="Finance">Finance</button>
                        <button class="search-btn" value="Business">Business</button>
                        <button class="search-btn" value="AI">AI</button>
                        <button class="search-btn" value="Economy">Economy</button>
                        <button class="search-btn" value="Health">Health</button>
                        <button class="search-btn" value="Entertainment">Entertainment</button>
                    </div>
                </div>
            </div>

            <div class="left-content">
                
                <div class="about-column">
                    <p class="title">About us</p>
                    <p class="content">
                        Ink Well is a modern blog focused on delivering simple, clear, and valuable content across
                        technology, finance, business, AI, health, and trending topics. <br><br>
                        Our goal is to make learning easy and accessible by sharing practical insights that help readers
                        stay informed and grow every day. <br><br>
                        We believe knowledge should be powerful — yet simple.
                        Welcome to Ink Well. 🚀
                    </p>
                </div>
                <div class="contact-column">
                    <p>Contact Us</p>
                    <div class="contact-logo">

                        <div class="social-icons">
                            <a href="https://facebook.com" target="_blank">
                                <i class="fab fa-facebook-f"></i>
                            </a>

                            <a href="https://instagram.com" target="_blank">
                                <i class="fab fa-instagram"></i>
                            </a>

                            <a href="https://twitter.com" target="_blank">
                                <i class="fab fa-x-twitter"></i>
                            </a>

                            <a href="https://linkedin.com" target="_blank">
                                <i class="fab fa-linkedin-in"></i>
                            </a>
                        </div>
                    </div>
                </div>
            </div>

        </div>

    </div>


    <script src="index.js"></script>
</body>

</html>